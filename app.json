{
  "expo": {
    "name": "BI Portal",
    "slug": "bi-portal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bimera",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.duyvanda.biportal",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Ứng dụng cần quyền Camera để chụp ảnh đính kèm vào câu hỏi cho BIRA.",
        "NSPhotoLibraryUsageDescription": "Ứng dụng cần quyền truy cập Thư viện ảnh để đính kèm file."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.duyvanda.biportal",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#00A79D"
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "Ứng dụng cần quyền truy cập thư viện ảnh để đính kèm hình ảnh.",
          "cameraPermission": "Ứng dụng cần quyền Camera để chụp ảnh đính kèm."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3f31a82-69ec-442a-aca5-2a375379a82c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a3f31a82-69ec-442a-aca5-2a375379a82c"
    }
  }
}