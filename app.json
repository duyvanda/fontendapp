{
  "expo": {
    "name": "BI Portal",
    "slug": "bi-portal",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "bimera",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.duyvanda.biportal",
      "deploymentTarget": "15.2",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Cho phép chụp ảnh để đính kèm vào câu hỏi và phân tích dữ liệu.",
        "NSPhotoLibraryUsageDescription": "Cho phép chọn ảnh để đính kèm vào câu hỏi.",
        "NSPhotoLibraryAddUsageDescription": "Cho phép lưu ảnh bạn chụp để sử dụng lại trong ứng dụng.",
        "NSMicrophoneUsageDescription": "Cho phép nhập câu hỏi bằng giọng nói thay vì gõ.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.duyvanda.biportal",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#00A79D"
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Cho phép chọn ảnh để đính kèm vào câu hỏi.",
          "cameraPermission": "Cho phép chụp ảnh để đính kèm vào câu hỏi và phân tích dữ liệu."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3f31a82-69ec-442a-aca5-2a375379a82c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a3f31a82-69ec-442a-aca5-2a375379a82c"
    }
  }
}
